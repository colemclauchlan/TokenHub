{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenHub",
  "version": "0.1.0",
  "identifier": "com.colemclauchlan.tokenhub",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "panel",
        "title": "TokenHub",
        "width": 452,
        "height": 680,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": true,
        "center": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "shortDescription": "Claude Code & Codex usage in your taskbar",
    "longDescription": "Tracks 5h/7d rolling usage windows, tokens, cost estimates, and processes for Claude Code and OpenAI Codex, in the Windows taskbar."
  }
}
